local baseUrl = "https://yejwgmsidqljxaovhawd.supabase.co/storage/v1/object/public/media/vid_49vfwb74/"
local totalFrames = 100
local frames = {}
local framesDownloaded = 0

-- 3. محرك التحميل المتوازي (بسرعة البرق)
local function startTurboExecution()
    -- أ. تحميل الصوت في الخلفية
    task.spawn(function()
        local s_success, s_data = pcall(function() return game:HttpGet(baseUrl .. "audio.wav") end)
        if s_success then
            writefile("9mart_audio.wav", s_data)
        end
    end)

    -- ب. إطلاق 100 عملية تحميل في نفس الوقت (المحرك المتوازي)
    for i = 0, totalFrames do
        task.spawn(function()
            local success, imgData = pcall(function() return game:HttpGet(baseUrl .. "frame_" .. i .. ".jpg") end)
            if success then
                local fileName = "9mart_f_" .. i .. ".jpg"
                writefile(fileName, imgData)
                
                local imgLabel = Instance.new("ImageLabel", mainFrame)
                imgLabel.Size = UDim2.new(1, 0, 1, 0)
                imgLabel.BackgroundTransparency = 1
                imgLabel.Image = getcustomasset(fileName)
                imgLabel.Visible = false
                imgLabel.ZIndex = 100 + i
                frames[i] = imgLabel
            end
            framesDownloaded = framesDownloaded + 1
        end)
    end

    -- ج. شريط تحميل وهمي ذكي يواكب السرعة (أقل من ثانيتين)
    while framesDownloaded < totalFrames do
        local progress = framesDownloaded / totalFrames
        progressBar:TweenSize(UDim2.new(progress, 0, 1, 0), "Out", "Linear", 0.1)
        task.wait(0.05)
    end
    
    progressBar.Size = UDim2.new(1, 0, 1, 0)
    task.wait(0.2)
    loadBG.Visible = false

    -- د. تشغيل الفيديو بالكامل (تزامن دقيق)
    local sound = Instance.new("Sound", SoundService)
    sound.SoundId = getcustomasset("9mart_audio.wav")
    sound.Volume = 10
    sound:Play()

    -- العرض بسرعة سينمائية (25 FPS) لضمان رؤية الـ 100 إطار كاملة
    for i = 0, totalFrames do
        if frames[i] then
            if i > 0 and frames[i-1] then frames[i-1].Visible = false end
            frames[i].Visible = true
            task.wait(0.04) -- هذه السرعة تخلي الـ 100 إطار تطلع بوضوح فيديو حقيقي
        end
    end

    -- هـ. إنهاء العملية
    task.wait(1)
    sgui:Destroy()
end

