-- محرك الاختراق النووي (Bypass Anti-Bang)
function createUltraBang(name, config)
    local active = false
    local connection = nil
    local togglePos = false

    BangTab:AddToggle({Name = name, Default = false, Callback = function(Value)
        active = Value
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        
        if Value then
            hum.PlatformStand = true
            -- استخدام RenderStepped لسبق المضاد في كل فريم
            connection = RunService.RenderStepped:Connect(function()
                if active and getgenv().selectedPlayer then
                    local target = Players:FindFirstChild(getgenv().selectedPlayer)
                    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                        local targetRoot = target.Character.HumanoidRootPart
                        
                        -- نظام الـ Bypass الحقيقي: إذا كان مكانه تحت -100000 (يعني مفعل مضاد) يتجاهل الإحداثية
                        local targetCF = targetRoot.CFrame
                        if targetCF.Y < -50000 then return end 

                        local speed = config.Speed or 0.05
                        local dist = (togglePos and config.Dist1) or config.Dist2
                        
                        local finalCF
                        if config.Type == "Back" then
                            finalCF = targetCF * CFrame.new(0, config.Y, dist)
                        elseif config.Type == "Face" then
                            finalCF = targetCF * CFrame.new(0, config.Y, -dist) * CFrame.Angles(0, math.rad(180), 0)
                        elseif config.Type == "Hand" then -- حركة اليد (التجليخ)
                            finalCF = targetCF * CFrame.new(0.5, config.Y, -dist) * CFrame.Angles(0, math.rad(180), math.rad(45))
                        end
                        
                        root.CFrame = finalCF
                        togglePos = not togglePos
                    end
                end
            end)
        else
            if connection then connection:Disconnect() end
            hum.PlatformStand = false
        end
    end})
end

