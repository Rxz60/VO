    label.Font = Enum.Font.GothamBlack
    label.TextSize = 25

-- 2. قوقعة الضوء (7 كرات طاقة تدور - أحمر وأخضر)
    for i = 1, 7 do
        local orbitAtt = Instance.new("Attachment", root)orbitAtt.Name = "KhalifaEffect"
        
        local p = Instance.new("ParticleEmitter", orbitAtt)
        p.Texture = "rbxassetid://6071575293"
        p.Color = ColorSequence.new(i % 2 == 0 and Color3.new(1, 0, 0) or Color3.new(0, 1, 0))
        p.Size = NumberSequence.new(10 * skySize)
        p.Lifetime = NumberRange.new(0.1)
