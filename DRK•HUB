        p.LockedToPart = false -- عشان تترك أثر ضوئي وراك
        
        -- تحريك يدوي للـ Attachment (هذا FE)
        task.spawn(function()
            while orbitAtt.Parent do
                local t = tick() * speedVal * 5
                local angle = math.rad((i * (360/7)) + (t * 50))
                orbitAtt.Position = Vector3.new(math.sin(angle) * 12, math.cos(t) * 3, math.cos(angle) * 12)
                task.wait()
            end
