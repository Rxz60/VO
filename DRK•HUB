-- محرك السرعة القصوى (تجاوز المضاد بنسبة 100%)
function createGodSpeedBang(name, config)
    local active = false
    local connection = nil
    local togglePos = false

    BangTab:AddToggle({Name = name, Default = false, Callback = function(Value)
        active = Value
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        if Value then
            hum.PlatformStand = true
            -- استخدام PreRender هو السر لسبق أي سكربت مضاد في السيرفر
            connection = RunService.PreRender:Connect(function()
                if active and getgenv().selectedPlayer then
                    local target = Players:FindFirstChild(getgenv().selectedPlayer)
                    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                        local targetRoot = target.Character.HumanoidRootPart
                        
                        -- Bypass Logic: تجاهل المواقع الوهمية (تحت الخريطة)
                        local targetCF = targetRoot.CFrame
                        if targetCF.Y < -1000 then 
                            -- محاولة استعادة الموقع الأصلي إذا كان الخصم يحاول الهرب تحت الأرض
                            targetCF = CFrame.new(targetCF.X, 0, targetCF.Z) 
                        end

                        -- سرعة الاهتزاز (الترليونية)
                        local dist = (togglePos and config.Dist1) or config.Dist2
                        local finalCF
                        
                        if config.Type == "Back" then
                            finalCF = targetCF * CFrame.new(0, config.Y, dist)
                        elseif config.Type == "Face" then
                            finalCF = targetCF * CFrame.new(0, config.Y, -dist) * CFrame.Angles(0, math.rad(180), 0)
                        elseif config.Type == "Hand" then
