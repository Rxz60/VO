local function CheckAndHidePlayer(plr)
	if not _G.HideNukePlayers then return end
	if not _G.HiddenPlayers then _G.HiddenPlayers = {} end
	if _G.HiddenPlayers[plr] then return end

	local char = plr.Character
	if not char then return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local found = false
	local tracks = hum:GetPlayingAnimationTracks()

	for _,tr in pairs(tracks) do
		if tr.Animation and tr.Animation.AnimationId == NUKE_ANIM then
			found = true
		end
	end

	local desc
	pcall(function()
		desc = hum:GetAppliedDescription()
	end)

	if desc then
		local ids = {
			desc.Torso,
			desc.RightArm,
			desc.LeftArm,
			desc.RightLeg,
			desc.LeftLeg,
			desc.Head
		}

		for _,id in pairs(ids) do
			if id and NUKE_BODY and NUKE_BODY[tostring(id)] then
				found = true
			end
		end
	end

	if not found then return end

	local saved = {
		parts = {},
		tracks = {}
	}

	for _,obj in pairs(char:GetDescendants()) do
		if obj:IsA("BasePart") then
			table.insert(saved.parts,obj)
			obj.LocalTransparencyModifier = 1
		end
	end

	for _,tr in pairs(tracks) do
		if tr.Animation and tr.Animation.AnimationId == NUKE_ANIM then
			table.insert(saved.tracks,tr)
			tr:Stop()
		end
	end

	_G.HiddenPlayers[plr] = saved

	Notify("تم اخفاء سكاي اللاعب: "..plr.Name)
end

