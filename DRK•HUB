        local target = Players:FindFirstChild(selectedPlayerName)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local originalPos = root.CFrame

        -- وظيفة جلب المركبة وتعزيز القوة
        local function GetVehicle()
            local v = workspace:FindFirstChild("Vehicles")
            return v and (v:FindFirstChild(LocalPlayer.Name .. "Car") or v:FindFirstChild(LocalPlayer.Name .. "Couch"))
        end

        local veh = GetVehicle()

        -- إذا لم تكن هناك مركبة، استدعي الباص فوراً (سرعة البرق)
        if not veh then
            root.CFrame = CFrame.new(1118.81, 75.998, -1138.61) -- إحداثيات ريسباون السيارات
            task.wait(0.1)
            local re = ReplicatedStorage:FindFirstChild("RE")
            if re and re:FindFirstChild("1Ca1r") then
                re["1Ca1r"]:FireServer("PickingCar", "SchoolBus")
            end
            repeat task.wait() veh = GetVehicle() until veh or not task.wait(1)
        end

        if veh then
            -- ركوب تلقائي فوري
            local seat = veh:FindFirstChildWhichIsA("VehicleSeat", true)
            if seat and not char.Humanoid.Sit then
                root.CFrame = seat.CFrame
                repeat task.wait() until char.Humanoid.Sit
            end

            -- خوارزمية الذبذبات المدمرة (أقوى دوران بالعالم)
            local killLoop
            killLoop = RunService.RenderStepped:Connect(function()
                if not target.Character or not veh.Parent or not char.Humanoid.Sit then
                    killLoop:Disconnect()
                    return
                end

                local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
                local tHum = target.Character:FindFirstChildOfClass("Humanoid")

                if tHum and tHum.Sit then
                    -- القتل النهائي (Void Banisher)
                    veh:SetPrimaryPartCFrame(CFrame.new(0, -500000, 0))
                    task.wait(0.1)
                    char.Humanoid.Jump = true
                    root.CFrame = originalPos
                    killLoop:Disconnect()
                else
                    -- ذبذبات جنونية (تردد 150 هرتز)
                    local t = tick() * 150
                    local rotOffset = CFrame.Angles(math.rad(t), math.rad(t), math.rad(t))
                    local posOffset = Vector3.new(math.sin(t)*15, math.cos(t)*5, math.cos(t)*15)
                    
                    -- تطبيق القوة الفيزيائية الخارقة
                    veh:SetPrimaryPartCFrame(CFrame.new(tRoot.Position + posOffset) * rotOffset)
                    
                    -- قوة دفع جانبية لمنع الهروب
                    veh.PrimaryPart.Velocity = Vector3.new(1000, 1000, 1000)
                    veh.PrimaryPart.RotVelocity = Vector3.new(1000, 1000, 1000)
                end
            end)
        end
    end
})

